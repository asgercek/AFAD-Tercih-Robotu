<script>
    window.onload = function() {
        formlariDoldur();
    };

    function formlariDoldur() {
        const kadrolar = JSON.parse(document.getElementById('kadroInput').value);
        
        let genisletilmisKadrolar = [];
        
        kadrolar.forEach(k => {
            for(let i = 1; i <= k.kontenjan; i++) {
                genisletilmisKadrolar.push({
                    id: k.id,
                    il: k.il,
                    unvan: k.unvan,
                    kadroSirasi: i,
                    toplamKadro: k.kontenjan
                });
            }
        });

        genisletilmisKadrolar.sort((a, b) => a.il.localeCompare(b.il, 'tr'));

        let optionsHTML = `<option value="">-- Tercih Yapılmadı --</option>`;
        genisletilmisKadrolar.forEach(k => {
            optionsHTML += `<option value="${k.id}">${k.il} - ${k.unvan} (${k.toplamKadro} Kadrodan ${k.kadroSirasi}.)</option>`;
        });

        for(let i = 1; i <= 15; i++) {
            document.getElementById(`tercih_${i}`).innerHTML = optionsHTML;
        }
    }

    function adayiListeyeEkle() {
        const isim = document.getElementById('formIsim').value.trim();
        const puan = parseFloat(document.getElementById('formPuan').value);

        if(!isim || isNaN(puan)) {
            alert("Lütfen isim ve puan alanlarını eksiksiz doldurun!");
            return;
        }

        const tercihler = [];
        for(let i = 1; i <= 15; i++) {
            const secilenDeger = document.getElementById(`tercih_${i}`).value;
            if(secilenDeger !== "") {
                tercihler.push(secilenDeger);
            }
        }

        if(tercihler.length === 0) {
            alert("Lütfen en az 1 tercih yapın!");
            return;
        }

        const yeniAday = {
            isim: isim,
            puan: puan,
            tercihler: tercihler
        };

        const adayTextarea = document.getElementById('adayInput');
        let mevcutAdaylar = [];
        try {
            mevcutAdaylar = JSON.parse(adayTextarea.value);
        } catch(e) {
            mevcutAdaylar = [];
        }

        mevcutAdaylar.push(yeniAday);
        adayTextarea.value = JSON.stringify(mevcutAdaylar, null, 2);

        document.getElementById('formIsim').value = "";
        document.getElementById('formPuan').value = "";
        for(let i = 1; i <= 15; i++) {
            document.getElementById(`tercih_${i}`).value = "";
        }

        alert(isim + " başarıyla veritabanına eklendi!");
    }

    function yerlestirmeyiBaslat() {
        let kadrolar, adaylar;
        try {
            kadrolar = JSON.parse(document.getElementById('kadroInput').value);
            adaylar = JSON.parse(document.getElementById('adayInput').value);
        } catch (e) {
            alert("Sistem arka planında veri okuma hatası oluştu.");
            return;
        }

        if (adaylar.length === 0) {
            alert("Yerleştirme yapabilmek için lütfen en az 1 aday ekleyin.");
            return;
        }

        const kadroMap = {};
        kadrolar.forEach(k => {
            kadroMap[k.id] = { ...k, kalanKontenjan: k.kontenjan };
        });

        adaylar.sort((a, b) => b.puan - a.puan);

        const sonuclar = [];

        adaylar.forEach(aday => {
            let yerlestiMi = false;
            let yerlesenKadro = null;
            let kacinciTercihi = 0;

            for (let i = 0; i < aday.tercihler.length; i++) {
                const tercihKodu = aday.tercihler[i];
                const hedefKadro = kadroMap[tercihKodu];

                if (hedefKadro && hedefKadro.kalanKontenjan > 0) {
                    hedefKadro.kalanKontenjan -= 1;
                    yerlestiMi = true;
                    yerlesenKadro = hedefKadro;
                    kacinciTercihi = i + 1;
                    break;
                }
            }

            sonuclar.push({
                isim: aday.isim,
                puan: aday.puan,
                durum: yerlestiMi,
                kadro: yerlesenKadro,
                tercihSirasi: kacinciTercihi
            });
        });

        const tbody = document.getElementById('sonucGövdesi');
        tbody.innerHTML = ''; 

        sonuclar.forEach((sonuc, index) => {
            const tr = document.createElement('tr');
            
            if (!sonuc.durum) {
                tr.className = 'unassigned';
            }

            tr.innerHTML = `
                <td>${index + 1}</td>
                <td><strong>${sonuc.isim}</strong></td>
                <td>${sonuc.puan}</td>
                <td>${sonuc.durum ? sonuc.kadro.il : '-'}</td>
                <td>${sonuc.durum ? sonuc.kadro.unvan : 'YERLEŞEMEDİ'}</td>
                <td>${sonuc.durum ? sonuc.tercihSirasi + '. Tercihi' : '-'}</td>
            `;
            tbody.appendChild(tr);
        });
    }
</script>

</body>
</html>

